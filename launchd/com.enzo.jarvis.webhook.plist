<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.enzo.jarvis.webhook</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "$HOME/Agent" &amp;&amp; set -a &amp;&amp; source .env 2&gt;/dev/null; set +a; exec "$HOME/Agent/webhook/.venv/bin/python" -m uvicorn webhook.server:app --host 0.0.0.0 --port 8787</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/jarvis-webhook.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/jarvis-webhook.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/enzopruano/.local/bin:/Users/enzopruano/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
