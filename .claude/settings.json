{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh api:*)",
      "Bash(yt-dlp:*)",
      "Bash(whisper:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(osascript:*)",
      "Bash(python3 scripts/*)",
      "Bash(bash scripts/*)",
      "Read(~/Documents/**)",
      "Read(~/Library/Mobile Documents/iCloud~md~obsidian/**)",
      "Write(~/Library/Mobile Documents/iCloud~md~obsidian/**)",
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "mcp__notion__*",
      "mcp__obsidian__*",
      "mcp__github__*",
      "mcp__gmail__*",
      "mcp__gcal__*",
      "mcp__filesystem__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "JARVIS_HOME": "${HOME}/Agent",
    "OBSIDIAN_VAULT": "${HOME}/Library/Mobile Documents/iCloud~md~obsidian/Documents/Enzo Vault",
    "JARVIS_LOG_DIR": "${HOME}/Library/Mobile Documents/iCloud~md~obsidian/Documents/Enzo Vault/Jarvis/log"
  },
  "mcpServers": {
    "notion": {
      "command": "bash",
      "args": ["scripts/mcp/notion.sh"]
    },
    "filesystem": {
      "command": "bash",
      "args": ["scripts/mcp/filesystem.sh"]
    },
    "github": {
      "command": "bash",
      "args": ["scripts/mcp/github.sh"]
    },
    "gmail": {
      "command": "bash",
      "args": ["scripts/mcp/gmail.sh"]
    },
    "gcal": {
      "command": "bash",
      "args": ["scripts/mcp/gcal.sh"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-stop.sh"
          }
        ]
      }
    ]
  }
}
