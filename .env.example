# ============================================================================
# Jarvis — variáveis de ambiente
# Copie este arquivo pra .env e preencha. Nunca commite .env.
# ============================================================================

# Core
JARVIS_HOME="$HOME/Agent"
JARVIS_TOKEN=gere_com_install_sh
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8787

# Destino das notificações
JARVIS_IMESSAGE_RECIPIENT="+5511XXXXXXXXX"

# Obsidian (ajuste se o vault está em outro lugar)
OBSIDIAN_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Main"

# Tailscale MagicDNS do Mac (pra referência — iPhone usa isso)
JARVIS_TAILSCALE_HOST="enzo-mac.tailnet-xxx.ts.net"

# Whisper
JARVIS_WHISPER_MODEL=small

# ============================================================================
# MCP servers
# ============================================================================
NOTION_TOKEN=ntn_...
GITHUB_TOKEN=github_pat_...

# Gmail: OAuth automático, sem token aqui.
# Google Calendar: JSON em ~/.config/jarvis/gcal-credentials.json
